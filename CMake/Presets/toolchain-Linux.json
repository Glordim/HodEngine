{
	"version": 10,
	"configurePresets": [
		{
			"name": "toolchain-linux-clang-x64",
			"hidden": true,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			},
			"toolchainFile": "${sourceDir}/CMake/Toolchains/linux-x86_64-clang.cmake"
		},
		{
			"name": "toolchain-linux-gcc-x64",
			"hidden": true,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			},
			"toolchainFile": "${sourceDir}/CMake/Toolchains/linux-x86_64-gcc.cmake"
		}
	]
}