@PACKAGE_INIT@

if(NOT DEFINED HOD_LIB_TYPE)
	set(HOD_LIB_TYPE "shared")
endif()

include(${CMAKE_CURRENT_LIST_DIR}/PlatformDetection.cmake)
include(${CMAKE_CURRENT_LIST_DIR}/Global.cmake)

set(_HOD_TARGETS_FILE "${CMAKE_CURRENT_LIST_DIR}/../platforms/${HOD_PLATFORM_NAME}/${HOD_ABI_NAME}/${HOD_LIB_TYPE}/cmake/HodEngineTargets.cmake")

if(EXISTS "${_HOD_TARGETS_FILE}")
	include("${_HOD_TARGETS_FILE}")

	set(HOD_TOOLCHAIN_FILE "${CMAKE_CURRENT_LIST_DIR}/../platforms/${HOD_PLATFORM_NAME}/${HOD_ABI_NAME}/${HOD_LIB_TYPE}/cmake/toolchain.cmake")
	if(NOT CMAKE_TOOLCHAIN_FILE)
		set(CMAKE_TOOLCHAIN_FILE "${HOD_TOOLCHAIN_FILE}" CACHE FILEPATH "HOD Engine Toolchain" FORCE)
	endif()

	set(HOD_TOOLS_DIR "${CMAKE_CURRENT_LIST_DIR}/../platforms/${HOD_PLATFORM_NAME}/${HOD_ABI_NAME}/${HOD_LIB_TYPE}/bin")

	set(HodEngine_FOUND TRUE)
else()
	set(HodEngine_FOUND FALSE)
	if(NOT HodEngine_FIND_QUIETLY)
		message(WARNING "HodEngine: Platform '${HOD_PLATFORM_NAME}/${HOD_ABI_NAME}' — variant '${HOD_LIB_TYPE}' not found (Checked: ${_HOD_TARGETS_FILE})")
	endif()
endif()

unset(_HOD_TARGETS_FILE)

set(_HOD_DEPS_DIR "${CMAKE_CURRENT_LIST_DIR}/../platforms/${HOD_PLATFORM_NAME}/${HOD_ABI_NAME}/deps")

find_package(fmt REQUIRED CONFIG
	PATHS "${_HOD_DEPS_DIR}/lib/cmake"
	NO_DEFAULT_PATH
	NO_CMAKE_FIND_ROOT_PATH
)

find_package(Freetype REQUIRED CONFIG
	PATHS "${_HOD_DEPS_DIR}/lib/cmake"
	NO_DEFAULT_PATH
	NO_CMAKE_FIND_ROOT_PATH
)

find_package(VulkanMemoryAllocator REQUIRED CONFIG
	PATHS "${_HOD_DEPS_DIR}/share/cmake"
	NO_DEFAULT_PATH
	NO_CMAKE_FIND_ROOT_PATH
)

if(NOT TARGET Box2d::Box2d)
	add_library(Box2d::Box2d STATIC IMPORTED)
	set_target_properties(Box2d::Box2d PROPERTIES
		IMPORTED_LOCATION "${_HOD_DEPS_DIR}/lib/${CMAKE_STATIC_LIBRARY_PREFIX}box2d${CMAKE_STATIC_LIBRARY_SUFFIX}"
		INTERFACE_INCLUDE_DIRECTORIES "${_HOD_DEPS_DIR}/include"
	)
endif()

if(NOT TARGET Stb::Stb)
	add_library(Stb::Stb INTERFACE IMPORTED)
	set_target_properties(Stb::Stb PROPERTIES
		INTERFACE_INCLUDE_DIRECTORIES "${_HOD_DEPS_DIR}/include"
	)
endif()

if(NOT TARGET PortableFileDialogs::PortableFileDialogs)
	add_library(PortableFileDialogs::PortableFileDialogs INTERFACE IMPORTED)
	set_target_properties(PortableFileDialogs::PortableFileDialogs PROPERTIES
		INTERFACE_INCLUDE_DIRECTORIES "${_HOD_DEPS_DIR}/include"
	)
endif()

if(WIN32 AND NOT TARGET WindowsHModular::WindowsHModular)
	add_library(WindowsHModular::WindowsHModular INTERFACE IMPORTED)
	set_target_properties(WindowsHModular::WindowsHModular PROPERTIES
		INTERFACE_INCLUDE_DIRECTORIES "${_HOD_DEPS_DIR}/include"
	)
endif()

if(NOT APPLE AND NOT ANDROID)
	find_package(VulkanHeaders REQUIRED CONFIG
		PATHS "${_HOD_DEPS_DIR}/share/cmake"
		NO_DEFAULT_PATH
	)
	find_package(VulkanLoader REQUIRED CONFIG
		PATHS "${_HOD_DEPS_DIR}/lib/cmake"
		NO_DEFAULT_PATH
	)
	if(NOT TARGET Vulkan::Vulkan)
		add_library(Vulkan::Vulkan INTERFACE IMPORTED)
		set_target_properties(Vulkan::Vulkan PROPERTIES
			INTERFACE_LINK_LIBRARIES "Vulkan::Loader;Vulkan::Headers"
		)
	endif()
elseif(ANDROID)
	find_library(vulkan-lib vulkan)
	add_library(Vulkan::Vulkan SHARED IMPORTED)
	set_target_properties(Vulkan::Vulkan PROPERTIES
		IMPORTED_LOCATION "${vulkan-lib}"
		INTERFACE_INCLUDE_DIRECTORIES "${ANDROID_NDK}/toolchains/llvm/prebuilt/${ANDROID_HOST_TAG}/sysroot/usr/include"
	)
endif()

if(ANDROID)
	add_library(AGDK::GameActitvity STATIC IMPORTED GLOBAL)
	set_target_properties(AGDK::GameActitvity PROPERTIES
		IMPORTED_LOCATION "${_HOD_DEPS_DIR}/lib/${CMAKE_STATIC_LIBRARY_PREFIX}game-activity_static${CMAKE_STATIC_LIBRARY_SUFFIX}"
		INTERFACE_INCLUDE_DIRECTORIES "${_HOD_DEPS_DIR}/include"
	)
endif()

unset(_HOD_DEPS_DIR)